// nasopenclaw-a — Anthropic / Claude
// Provider: anthropic  |  Port: 18790
// Env vars required: ANTHROPIC_API_KEY, TELEGRAM_BOT_TOKEN
{
  gateway: {
    port: 18789,
    mode: "local",
    bind: "0.0.0.0",
    auth: {
      mode: "token",
      token: "nasopenclaw-a-change-me",
    },
    logging: {
      redactSensitive: true,
    },
  },
  models: {
    providers: {
      anthropic: {
        apiKey: "${ANTHROPIC_API_KEY}",
      },
    },
  },
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "anthropic/claude-sonnet-4-5",
        fallbacks: [
          "anthropic/claude-haiku-4-5",
        ],
      },
    },
  },
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "pairing",
      groups: {
        "*": {
          requireMention: true,
          systemPrompt: "Git workflow:\n1. On first coding request, clone the repo to /tmp/<project> using: git clone https://git:$GITHUB_TOKEN@github.com/ORG/REPO.git /tmp/<project>\n2. cd into /tmp/<project> and work there\n3. Create a feature branch for your changes\n4. Commit and push frequently as you work\n5. Always commit and push before finishing a task\n6. /tmp is ephemeral — nothing persists after container restart\n\nAsk which repo to work on if the user hasn't specified one.",
        },
      },
    },
  },
}

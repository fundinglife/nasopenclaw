// nasopenclaw-g — Gemini via CLIProxy
// Provider: CLIProxy (openai-completions)  |  Port: 18792
// No API key needed — CLIProxy handles Gemini CLI OAuth on RO-WIN
// CLIProxy external URL: https://aiproxy.rohitsoni.com
// Models: gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
{
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "nasopenclaw-g-change-me"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "cliproxy": {
        "baseUrl": "https://aiproxy.rohitsoni.com/v1",
        "apiKey": "unused",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro (via CLIProxy)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash (via CLIProxy)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "gemini-2.5-flash-lite",
            "name": "Gemini 2.5 Flash Lite (via CLIProxy)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 65536
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "cliproxy/gemini-2.5-pro",
        "fallbacks": [
          "cliproxy/gemini-2.5-flash",
          "cliproxy/gemini-2.5-flash-lite"
        ]
      },
      "models": {
        "cliproxy/gemini-2.5-pro": { "alias": "pro" },
        "cliproxy/gemini-2.5-flash": { "alias": "flash" },
        "cliproxy/gemini-2.5-flash-lite": { "alias": "lite" }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": { "*": { "requireMention": true } }
    }
  }
}
